{
  "installCommand": "pnpm install",
  "buildCommand": "pnpm run build",
  "outputDirectory": "artifacts/elite-tenancy/dist",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "artifacts/api-server/src/index.ts" },
    { "source": "/(.*)", "destination": "artifacts/elite-tenancy/dist/index.html" }
  ]
}
